# ─────────────────────────────────────────────────────────────────────────────
# PlutusClub — Environment Variables
# Copy to .env.local and fill in all values before running.
# See docs/DEPLOYMENT.md for detailed setup instructions.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # NEVER expose to browser

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://plutusclub.in              # No trailing slash
APP_SECRET=change-this-to-a-random-32-plus-char-string # Used for session signing
CSRF_SECRET=another-random-32-plus-char-string         # CSRF token signing
OTP_SIGNING_SECRET=random-32-plus-char-string-for-otp  # HMAC key for hashing OTP codes
EMAIL_TOKEN_SECRET=random-32-plus-char-string-for-email # HMAC key for hashing email tokens
INTERNAL_JOB_TOKEN=random-token-for-cron-jobs          # Bearer token for /api/internal/*

# ── Payment gateway (configure via Admin → Settings → Providers) ─────────────
# These are only needed if you bypass the admin panel provider config.
# Recommended: leave blank and configure via admin panel after first deploy.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Redis (BullMQ worker + OTP rate limiting) ─────────────────────────────────
# Get from Upstash (https://console.upstash.com/) or Railway Redis
REDIS_URL=redis://default:password@your-redis-host:6379
# Legacy Upstash REST API (used by lib/security/rate-limit.ts)
UPSTASH_REDIS_URL=https://your-db.upstash.io
UPSTASH_REDIS_TOKEN=your-upstash-token

# ── AI / Anthropic ───────────────────────────────────────────────────────────
# Powers AI concierge first-response draft (POST /api/concierge/ai-assist)
ANTHROPIC_API_KEY=sk-ant-api03-...
AI_MONTHLY_BUDGET_USD=500
AI_FEATURES_ENABLED=recommendations,fraud,churn   # comma-separated feature list

# ── SIEM / Audit forwarding (optional) ───────────────────────────────────────
# If set, all audit log events are also forwarded here as POST JSON
SIEM_WEBHOOK_URL=

# ── Vercel Cron (set in vercel.json, not here) ────────────────────────────────
# See docs/DEPLOYMENT.md → "Cron Jobs" section for vercel.json config
# POST /api/internal/memberships/renew      — daily  02:00 IST
# POST /api/internal/notifications/dispatch — every 5 min
# POST /api/internal/lifecycle/reminders    — daily  08:00 IST

# ─────────────────────────────────────────────────────────────────────────────
# NOTE: Payment, SMS, and Email provider credentials are configured via the
# Admin Panel (Admin → Settings → Providers & Integrations) and stored in the
# provider_config database table. You do NOT need to add them here.
# ─────────────────────────────────────────────────────────────────────────────
